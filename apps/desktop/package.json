{
  "name": "gatekeeper-desktop",
  "version": "1.3.0",
  "description": "Gatekeeper Desktop - Intel & Route Planning",
  "main": "src/main.js",
  "author": "AreteDriver",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "npm run build:web && electron-builder",
    "build:web": "cd ../mobile && npx expo export --platform web && cp -r dist ../desktop/web-build",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.evegatekeeper.desktop",
    "productName": "Gatekeeper",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "web-build/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "assets"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "devDependencies": {
    "electron": "^39.8.4",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "overrides": {
    "tar": ">=7.5.11",
    "picomatch": ">=4.0.2"
  }
}
